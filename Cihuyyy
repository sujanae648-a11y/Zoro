                        <i class="ph-fill ph-heart text-sm"></i>
                    </button>
                    
                    <!-- Image -->
                    <div class="relative w-full aspect-square rounded-2xl overflow-hidden mb-3 bg-slate-100 dark:bg-slate-900">
                        <img src="${product.image}" alt="${product.name}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy">
                        ${product.badge ? `
                            <div class="absolute top-2 left-2 ${product.badgeColor} text-white text-[9px] font-bold px-2 py-1 rounded-full shadow-sm">
                                ${product.badge}
                            </div>
                        ` : ''}
                    </div>
                    
                    <!-- Details -->
                    <div>
                        <h4 class="text-sm font-medium text-slate-800 dark:text-slate-200 line-clamp-1 mb-1">${product.name}</h4>
                        <div class="flex items-center justify-between mt-2">
                            <span class="text-sm font-bold text-purple-600 dark:text-purple-400">${formatRupiah(product.price)}</span>
                            <button onclick="addToCart()" class="w-8 h-8 bg-slate-900 dark:bg-slate-100 text-white dark:text-slate-900 rounded-full flex items-center justify-center hover:scale-110 transition-transform active:scale-95">
                                <i class="ph ph-plus font-bold"></i>
                            </button>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        // --- 3. Shopping Cart Logic ---
        let cartCount = 0;
        const badge = document.getElementById('cartBadge');
        const toast = document.getElementById('toast');

        function addToCart() {
            cartCount++;
            badge.textContent = cartCount;
            // Pop animation for badge
            badge.classList.remove('scale-0');
            badge.classList.add('scale-100');
            badge.classList.add('animate-bounce');
            setTimeout(() => badge.classList.remove('animate-bounce'), 1000);

            // Show Toast Notification
            toast.classList.remove('-translate-y-20', 'opacity-0');
            toast.classList.add('translate-y-0', 'opacity-100');
            
            // Haptic feedback for mobile devices
            if (navigator.vibrate) navigator.vibrate(50);

            setTimeout(() => {
                toast.classList.remove('translate-y-0', 'opacity-100');
                toast.classList.add('-translate-y-20', 'opacity-0');
            }, 2500);
        }

        // --- 4. Dark Mode Logic ---
        const themeToggleBtn = document.getElementById('themeToggle');
        
        // Cek preferensi user (Local Storage atau OS setting)
        if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }

        themeToggleBtn.addEventListener('click', function() {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('color-theme', 'light');
            } else {
                document.documentElement.classList.add('dark');
                localStorage.setItem('color-theme', 'dark');
            }
        });

        // --- 5. AI Chat Modal Logic ---
        const aiModal = document.getElementById('aiChatModal');
        const aiContent = document.getElementById('aiChatContent');
        let isChatOpen = false;

        function toggleAIChat() {
            isChatOpen = !isChatOpen;
            if (isChatOpen) {
                aiModal.classList.remove('hidden');
                // Slight delay to allow display:block to apply before animating opacity
                setTimeout(() => {
                    aiModal.classList.remove('opacity-0');
                    aiContent.classList.remove('translate-y-full');
                }, 10);
            } else {
                aiModal.classList.add('opacity-0');
                aiContent.classList.add('translate-y-full');
                // Wait for animation to finish before hiding
                setTimeout(() => {
                    aiModal.classList.add('hidden');
                }, 300);
            }
        }

        // Initialize App
        renderProducts();

    </script>
</body>
