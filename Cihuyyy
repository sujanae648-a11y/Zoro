                name: "Chunky Sneakers",
                price: 450000,
                image: "https://images.unsplash.com/photo-1542291026-7eec264c27ff?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80",
                badge: "",
                badgeColor: ""
            }
        ];

        // Format currency helper
        const formatRupiah = (number) => {
            return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(number);
        };

        // --- 2. Render Products ---
        const productGrid = document.getElementById('productGrid');
        
        function renderProducts() {
            productGrid.innerHTML = products.map(product => `
                <div class="bg-white dark:bg-slate-800 rounded-3xl p-3 shadow-sm border border-slate-100 dark:border-slate-700/50 group relative hover:-translate-y-1 transition-transform duration-300">
                    <!-- Wishlist button -->
